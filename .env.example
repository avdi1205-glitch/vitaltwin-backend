STRIPE_SECRET_KEY=
# Legacy single-tier price ID. Still honored as a fallback for premium/monthly
# if STRIPE_PRICE_PREMIUM_MONTHLY is not set (see backend/app/core/plans.py).
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
STRIPE_TRIAL_DAYS=0
FRONTEND_BASE_URL=https://www.vitaltwin.de
