# Per-plan, per-interval Stripe Price IDs (Block 3: Preisseite/Tarifstruktur).
# Leave a variable empty/unset if that plan+interval isn't sellable yet —
# the backend will reject checkout attempts for it with a clear error
# instead of charging an unintended price.
STRIPE_PRICE_PREMIUM_MONTHLY=
STRIPE_PRICE_PREMIUM_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_FAMILY_MONTHLY=
STRIPE_PRICE_FAMILY_YEARLY=

# "Frag deinen Twin" wellness assistant (Block 6). Leave empty and the chat
# endpoint responds with a clear "currently unavailable" message instead of
# crashing — no fake/placeholder key is ever used.
OPENAI_API_KEY=
# Optional, defaults to gpt-4o-mini if unset.
OPENAI_MODEL=
